.PHONY: all generate-all clean

all:
	bash -ec 'for f in *.cf; do js="$${f%.cf}".expected.js && rm -rfv $$js && $(MAKE) $$js; done'
	$(MAKE) test-generate
	git diff --exit-code --stat './*.js'

%.expected.js: %.cf
	d=`mktemp -d` && \
		cabal run bnfc -- -o $$d --tree-sitter $< && \
		grep -v 'File generated by' $$d/tree-sitter-*/grammar.js > $@ && \
		rm -rf $$d

generate-all:
	bash -ec 'for f in *.cf; do $(MAKE) generate-"$${f%.cf}"; done'

generate-%: %.cf
	cabal run bnfc -- -o tmp-$@ --tree-sitter --makefile $<
	make -C tmp-$@/tree-sitter-*

clean:
	rm -rfv test-*
	git restore -- './*.js'
